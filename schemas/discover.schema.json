{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscoveryResult",
  "type": "object",
  "properties": {
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CudaProcessCandidate"
      }
    },
    "limit": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "ok": {
      "type": "boolean"
    },
    "root": {
      "$ref": "#/$defs/TargetIdentity"
    },
    "schema_version": {
      "$ref": "#/$defs/DiscoverySchemaVersion"
    },
    "total_candidates": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "warnings": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Warning"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "root",
    "limit",
    "total_candidates",
    "truncated",
    "candidates"
  ],
  "$defs": {
    "CudaProcessCandidate": {
      "type": "object",
      "properties": {
        "command_line": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "executable": {
          "type": "string"
        },
        "gpu_uuids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parent_pid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "target": {
          "$ref": "#/$defs/TargetIdentity"
        }
      },
      "additionalProperties": false,
      "required": [
        "target",
        "parent_pid",
        "executable",
        "command_line",
        "gpu_uuids"
      ]
    },
    "DiscoverySchemaVersion": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "TargetIdentity": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "process_start_time": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "pid",
        "process_start_time"
      ]
    },
    "Warning": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    }
  }
}
