{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcessReport",
  "type": "object",
  "properties": {
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "cgroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CgroupEntry"
      }
    },
    "command_line": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "credentials": {
      "$ref": "#/$defs/ProcessCredentials"
    },
    "cuda": {
      "$ref": "#/$defs/ProcessCudaState"
    },
    "executable": {
      "type": "string"
    },
    "loaded_libraries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mount_namespace": {
      "type": "string"
    },
    "namespace_pids": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0
      }
    },
    "ok": {
      "type": "boolean"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    },
    "target": {
      "$ref": "#/$defs/TargetIdentity"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "target",
    "executable",
    "command_line",
    "credentials",
    "namespace_pids",
    "mount_namespace",
    "cgroups",
    "loaded_libraries",
    "cuda",
    "capabilities"
  ],
  "$defs": {
    "Capabilities": {
      "type": "object",
      "properties": {
        "cuda_activity": {
          "type": "boolean"
        },
        "cuda_callback": {
          "type": "boolean"
        },
        "runtime_injection": {
          "type": "boolean"
        },
        "tracepoint": {
          "type": "boolean"
        },
        "uprobe": {
          "type": "boolean"
        },
        "uretprobe": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "uprobe",
        "uretprobe",
        "tracepoint",
        "cuda_callback",
        "cuda_activity",
        "runtime_injection"
      ]
    },
    "CgroupEntry": {
      "type": "object",
      "properties": {
        "controllers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hierarchy_id": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "hierarchy_id",
        "controllers",
        "path"
      ]
    },
    "CheckResult": {
      "type": "object",
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/CheckStatus"
        }
      },
      "additionalProperties": false,
      "required": [
        "status"
      ]
    },
    "CheckStatus": {
      "type": "string",
      "enum": [
        "available",
        "restricted",
        "unavailable",
        "unknown"
      ]
    },
    "ProcessCredentials": {
      "type": "object",
      "properties": {
        "effective_gid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "effective_uid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "filesystem_gid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "filesystem_uid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "real_gid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "real_uid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "saved_gid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "saved_uid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "real_uid",
        "effective_uid",
        "saved_uid",
        "filesystem_uid",
        "real_gid",
        "effective_gid",
        "saved_gid",
        "filesystem_gid"
      ]
    },
    "ProcessCudaState": {
      "type": "object",
      "properties": {
        "context": {
          "$ref": "#/$defs/CheckResult"
        },
        "libcuda_loaded": {
          "type": "boolean"
        },
        "libcudart_loaded": {
          "type": "boolean"
        },
        "xprobe_cupti_loaded": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "libcuda_loaded",
        "libcudart_loaded",
        "xprobe_cupti_loaded",
        "context"
      ]
    },
    "SchemaVersion": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "TargetIdentity": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "process_start_time": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "pid",
        "process_start_time"
      ]
    }
  }
}
