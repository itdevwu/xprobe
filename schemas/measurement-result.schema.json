{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MeasurementResult",
  "type": "object",
  "properties": {
    "clock": {
      "$ref": "#/$defs/ClockQuality"
    },
    "collection": {
      "$ref": "#/$defs/CollectionSummary"
    },
    "correlation": {
      "$ref": "#/$defs/CorrelationSummary"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MatchedEventPair"
      }
    },
    "measurement": {
      "$ref": "#/$defs/Measurement"
    },
    "ok": {
      "type": "boolean"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    },
    "session_id": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SessionStatus"
    },
    "warnings": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Warning"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "session_id",
    "status",
    "measurement",
    "correlation",
    "clock",
    "collection",
    "evidence"
  ],
  "$defs": {
    "ArgumentValue": {
      "type": "object",
      "properties": {
        "abi_type": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "read_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": true
      },
      "additionalProperties": false,
      "required": [
        "index",
        "abi_type"
      ]
    },
    "CaptureCompleteness": {
      "type": "string",
      "enum": [
        "complete"
      ]
    },
    "ClockDomain": {
      "type": "string",
      "enum": [
        "host_monotonic",
        "cupti",
        "cupti_normalized_to_host_monotonic"
      ]
    },
    "ClockQuality": {
      "type": "object",
      "properties": {
        "alignment": {
          "type": "string"
        },
        "estimated_error_ns": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "alignment"
      ]
    },
    "CollectionSummary": {
      "type": "object",
      "properties": {
        "completeness": {
          "$ref": "#/$defs/CaptureCompleteness"
        },
        "cuda_events": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "cupti": {
          "anyOf": [
            {
              "$ref": "#/$defs/CuptiCollectionSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "dropped_events": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "host_events": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "completeness",
        "host_events",
        "cuda_events",
        "dropped_events"
      ]
    },
    "CorrelationConfidence": {
      "type": "string",
      "enum": [
        "exact",
        "high",
        "heuristic",
        "ambiguous"
      ]
    },
    "CorrelationSummary": {
      "type": "object",
      "properties": {
        "confidence": {
          "$ref": "#/$defs/CorrelationConfidence"
        },
        "method": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "method",
        "confidence",
        "score"
      ]
    },
    "CudaEvent": {
      "type": "object",
      "properties": {
        "block": {
          "anyOf": [
            {
              "$ref": "#/$defs/Dim3"
            },
            {
              "type": "null"
            }
          ]
        },
        "bytes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "callback_domain": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "callback_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "context_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "correlation_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "device_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "end_ns": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "grid": {
          "anyOf": [
            {
              "$ref": "#/$defs/Dim3"
            },
            {
              "type": "null"
            }
          ]
        },
        "kernel_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "kernel_name_mangled": {
          "type": [
            "string",
            "null"
          ]
        },
        "memcpy_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemcpyKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime_correlation_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "start_ns": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "stream_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "CuptiCollectionSummary": {
      "type": "object",
      "properties": {
        "buffer_utilization": {
          "type": "number",
          "format": "double"
        },
        "dropped_records": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "observed_records": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "record_capacity": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "retained_records": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "record_capacity",
        "observed_records",
        "retained_records",
        "dropped_records",
        "buffer_utilization"
      ]
    },
    "Dim3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "z": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ]
    },
    "Event": {
      "type": "object",
      "properties": {
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "clock_domain": {
          "$ref": "#/$defs/ClockDomain"
        },
        "cpu": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "cuda": {
          "anyOf": [
            {
              "$ref": "#/$defs/CudaEvent"
            },
            {
              "type": "null"
            }
          ]
        },
        "event_id": {
          "type": "string"
        },
        "event_type": {
          "$ref": "#/$defs/EventType"
        },
        "host": {
          "anyOf": [
            {
              "$ref": "#/$defs/HostEvent"
            },
            {
              "type": "null"
            }
          ]
        },
        "pid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "process_start_time": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "schema_version": {
          "$ref": "#/$defs/SchemaVersion"
        },
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "session_id": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/EventSource"
        },
        "tid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "timestamp_error_ns": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "timestamp_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "timestamp_raw": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "session_id",
        "event_id",
        "sequence",
        "source",
        "event_type",
        "pid",
        "tid",
        "timestamp_raw",
        "timestamp_ns",
        "clock_domain"
      ]
    },
    "EventSource": {
      "type": "string",
      "enum": [
        "ebpf",
        "cupti_callback",
        "cupti_activity",
        "marker"
      ]
    },
    "EventType": {
      "type": "string",
      "enum": [
        "host_function_entry",
        "host_function_exit",
        "kernel_function_entry",
        "kernel_function_exit",
        "tracepoint",
        "syscall_entry",
        "syscall_exit",
        "cuda_api_entry",
        "cuda_api_exit",
        "gpu_kernel_start",
        "gpu_kernel_end",
        "gpu_memcpy_start",
        "gpu_memcpy_end",
        "gpu_memset_start",
        "gpu_memset_end",
        "marker"
      ]
    },
    "HostEvent": {
      "type": "object",
      "properties": {
        "arguments": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ArgumentValue"
          }
        },
        "binary_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "build_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "probe_kind": {
          "$ref": "#/$defs/HostProbeKind"
        },
        "return_value": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "symbol": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "probe_kind"
      ]
    },
    "HostProbeKind": {
      "type": "string",
      "enum": [
        "uprobe",
        "uretprobe",
        "kprobe",
        "kretprobe",
        "tracepoint",
        "syscall",
        "usdt"
      ]
    },
    "LatencyStatistics": {
      "type": "object",
      "properties": {
        "max": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "mean": {
          "type": "number",
          "format": "double"
        },
        "min": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "p50": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "p90": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "p95": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "p99": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "min",
        "mean",
        "p50",
        "p90",
        "p95",
        "p99",
        "max"
      ]
    },
    "MatchedEventPair": {
      "type": "object",
      "properties": {
        "end": {
          "$ref": "#/$defs/Event"
        },
        "latency_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "start": {
          "$ref": "#/$defs/Event"
        }
      },
      "additionalProperties": false,
      "required": [
        "start",
        "end",
        "latency_ns"
      ]
    },
    "Measurement": {
      "type": "object",
      "properties": {
        "latency_ns": {
          "$ref": "#/$defs/LatencyStatistics"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "samples": {
          "$ref": "#/$defs/SampleSummary"
        }
      },
      "additionalProperties": false,
      "required": [
        "samples",
        "latency_ns"
      ]
    },
    "MemcpyKind": {
      "type": "string",
      "enum": [
        "HtoD",
        "DtoH",
        "DtoD",
        "HtoH",
        "PtoP",
        "unknown"
      ]
    },
    "SampleSummary": {
      "type": "object",
      "properties": {
        "ambiguous": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "dropped": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "matched": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "unmatched_end": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "unmatched_start": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "matched",
        "unmatched_start",
        "unmatched_end",
        "ambiguous",
        "dropped"
      ]
    },
    "SchemaVersion": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "SessionStatus": {
      "type": "string",
      "enum": [
        "completed",
        "timed_out",
        "cancelled",
        "failed"
      ]
    },
    "Warning": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    }
  }
}
