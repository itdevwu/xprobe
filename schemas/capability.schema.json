{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilityReport",
  "type": "object",
  "properties": {
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "checks": {
      "$ref": "#/$defs/SystemChecks"
    },
    "environment": {
      "$ref": "#/$defs/Environment"
    },
    "ok": {
      "type": "boolean"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    },
    "warnings": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Warning"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "capabilities",
    "environment",
    "checks"
  ],
  "$defs": {
    "Capabilities": {
      "type": "object",
      "properties": {
        "cuda_activity": {
          "type": "boolean"
        },
        "cuda_callback": {
          "type": "boolean"
        },
        "runtime_injection": {
          "type": "boolean"
        },
        "tracepoint": {
          "type": "boolean"
        },
        "uprobe": {
          "type": "boolean"
        },
        "uretprobe": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "uprobe",
        "uretprobe",
        "tracepoint",
        "cuda_callback",
        "cuda_activity",
        "runtime_injection"
      ]
    },
    "CheckResult": {
      "type": "object",
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/CheckStatus"
        }
      },
      "additionalProperties": false,
      "required": [
        "status"
      ]
    },
    "CheckStatus": {
      "type": "string",
      "enum": [
        "available",
        "restricted",
        "unavailable",
        "unknown"
      ]
    },
    "Environment": {
      "type": "object",
      "properties": {
        "architecture": {
          "type": "string"
        },
        "container": {
          "type": [
            "string",
            "null"
          ]
        },
        "effective_uid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "kernel_release": {
          "type": "string"
        },
        "operating_system": {
          "type": "string"
        },
        "pid_namespace": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "operating_system",
        "architecture",
        "kernel_release",
        "effective_uid",
        "pid_namespace"
      ]
    },
    "SchemaVersion": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "SystemChecks": {
      "type": "object",
      "properties": {
        "btf": {
          "$ref": "#/$defs/CheckResult"
        },
        "cuda_driver": {
          "$ref": "#/$defs/CheckResult"
        },
        "cuda_toolkit": {
          "$ref": "#/$defs/CheckResult"
        },
        "cupti": {
          "$ref": "#/$defs/CheckResult"
        },
        "ebpf_permissions": {
          "$ref": "#/$defs/CheckResult"
        },
        "kernel_lockdown": {
          "$ref": "#/$defs/CheckResult"
        },
        "nvidia_driver": {
          "$ref": "#/$defs/CheckResult"
        },
        "perf_event_paranoid": {
          "$ref": "#/$defs/CheckResult"
        },
        "ptrace_scope": {
          "$ref": "#/$defs/CheckResult"
        }
      },
      "additionalProperties": false,
      "required": [
        "btf",
        "ebpf_permissions",
        "kernel_lockdown",
        "perf_event_paranoid",
        "ptrace_scope",
        "nvidia_driver",
        "cuda_driver",
        "cuda_toolkit",
        "cupti"
      ]
    },
    "Warning": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    }
  }
}
